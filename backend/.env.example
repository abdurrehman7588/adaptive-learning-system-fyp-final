PORT=5000
NODE_ENV=development

# Auth rate limit applies in production only (login/register POST). Development disables it by default.
# DISABLE_AUTH_RATE_LIMIT=true
# AUTH_RATE_LIMIT_MAX=30
# AUTH_RATE_LIMIT_WINDOW_MS=900000

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/adaptive_learning

JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:5173

# Google OAuth (optional — email/password works for local demo)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Demo parent (seeded when running npm run db:seed)
DEMO_PARENT_EMAIL=parent@demo.com
DEMO_PARENT_PASSWORD=password123

# Admin tooling (optional)
ADMIN_EMAIL=
ADMIN_PASSWORD=
